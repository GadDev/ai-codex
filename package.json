{
	"name": "ai-codex",
	"version": "1.0.0",
	"description": "AI Codex — a modern, offline-first PWA for exploring AI & Claude development notes.",
	"type": "module",
	"engines": {
		"node": ">=24",
		"npm": ">=10"
	},
	"scripts": {
		"dev": "vite",
		"predev": "tsx scripts/build-manifest.ts",
		"build:manifest": "tsx scripts/build-manifest.ts",
		"build": "npm run build:manifest && tsc --noEmit && vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^3.2.4",
		"fuse.js": "^7.3.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.4.0",
		"semantic-release": "^25.0.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^6.4.2",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"dompurify": "^3.4.0",
		"highlight.js": "^11.11.1",
		"marked": "^18.0.0"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"biome check --write --no-errors-on-unmatched",
			"biome format --write --no-errors-on-unmatched"
		],
		"*.{js,json,css,md}": [
			"biome format --write --no-errors-on-unmatched"
		]
	}
}

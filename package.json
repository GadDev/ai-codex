{
	"name": "claude-code-docs",
	"version": "1.0.0",
	"description": "A personal learning knowledge base about Claude, the Anthropic ecosystem, and AI development — alongside a working web app that serves and searches those notes.",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"predev": "tsx scripts/build-manifest.ts",
		"build:manifest": "tsx scripts/build-manifest.ts",
		"build": "npm run build:manifest && tsc --noEmit && vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^3.2.4",
		"fuse.js": "^7.3.0",
		"jsdom": "^26.1.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^6.4.2",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"dompurify": "^3.4.0",
		"highlight.js": "^11.11.1",
		"marked": "^18.0.0"
	}
}

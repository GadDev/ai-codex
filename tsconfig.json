{
	"compilerOptions": {
		/* Language */
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],

		/* Strictness */
		"strict": true,
		"noImplicitOverride": true,

		/* Node built-in types (required for scripts/*.ts) */
		"types": ["node"],

		/* Skip type-checking of declaration files in node_modules */
		"skipLibCheck": true,

		/* Output — Vite handles transpilation; tsc is type-check only */
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,

		/* Source maps for IDE navigation */
		"sourceMap": true,
		"declaration": false
	},
	"include": ["src/**/*", "scripts/**/*", "tests/**/*", "vite.config.ts"],
	"exclude": ["node_modules", "dist"]
}
